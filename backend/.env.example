# QuickRoom backend config. Copy to ".env" (gitignored) and fill in.
# docker compose reads .env automatically.

# Mode: "mock" (default, no creds), "live" (admin S2S), or "user" (your own OAuth).
ZOOM_MODE=user

# --- user mode (User-managed OAuth app) ---
# From your Zoom App Marketplace > Develop > Build App > User-managed OAuth app.
# App's "Redirect URL for OAuth" AND "OAuth allow list" must contain:
#   http://localhost:8080/oauth/callback
# Scope to add: workspace:read:list_reservations
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# --- live mode (admin Server-to-Server OAuth) only ---
ZOOM_ACCOUNT_ID=
ZOOM_LOCATION_ID=

# TezTun tunnel (https://room.teztun.uz). Mint at https://app.teztun.uz/tokens
TEZTUN_TOKEN=
